# GitHub Personal Access Token with models:read scope
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_pat_here

# Primary model — gpt-4o is "High" tier: 50 req/day, 10 req/min
MODEL=gpt-4o

# Fallback model — NOTE: gpt-5 is even more restricted (8 req/day)
# Consider gpt-4o-mini (Low tier, 150 req/day) as a better fallback
MODEL_UPGRADE=gpt-5

# Optional model prototype, eg; free tier
MODEL_PROTOTYPE=gpt-4o-mini